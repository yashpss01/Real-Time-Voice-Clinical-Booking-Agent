# ==============================================================================
# Real-Time Multilingual Voice AI Agent - Configuration Settings Template
# ==============================================================================

# 1. Core API Credentials
# Google AI Studio API Key (For Gemini 3.5 Flash LLM and Reasoning Engine)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. Database & Cache Connections
# PostgreSQL Persistent Database URL (Using Supabase)
DATABASE_URL=postgresql://username:password@hostname:5432/postgres

# Redis Session Store and Message Cache Connection URL (Upstash Redis)
# Note: "rediss://" (with two 's') is used to enable secure SSL/TLS connection required by Upstash
REDIS_URL=rediss://default:token@hostname:6379
UPSTASH_REDIS_REST_URL=https://hostname
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# 3. Connection & Routing Settings (For Backend FastAPI & Next.js Frontend)
PORT=8000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# 4. Local Inference Controls
WHISPER_MODEL_SIZE=base        # Choices: tiny, base, small (smaller is faster for cpu)
USE_GPU=False                  # Set to True if your environment has an NVIDIA GPU configured with CUDA

# 5. Logging and Debug Settings
LOG_LEVEL=INFO                 # Choices: DEBUG, INFO, WARNING, ERROR
DEBUG=True
